generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  orders    Order[]
  cartItems CartItem[]
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  menus       Menu[]
  orders      Order[]
}

model Menu {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  name         String
  price        Int
  description  String?
  imageUrl     String?
  options      Json?       // 메뉴 선택 옵션 스키마 저장용 (ex: 사이드, 음료)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
  cartItems    CartItem[]
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  totalPrice   Int
  status       String      @default("PENDING") // PENDING, COOKING, DELIVERING, COMPLETED
  address      String?     // 배달 주소
  phone        String?     // 연락처
  requests     String?     // 요청사항
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  menuId    String
  menu      Menu     @relation(fields: [menuId], references: [id])
  quantity  Int
  price     Int      // Snapshot of menu price at the time of order
  selectedOptions Json? // 주문 시 선택한 옵션
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  menuId    String
  menu      Menu     @relation(fields: [menuId], references: [id])
  quantity  Int      @default(1)
  selectedOptions Json? // 담을 때 선택한 옵션
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
